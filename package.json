{
  "name": "hnet-manager",
  "version": "1.0.0",
  "description": "",
  "main": "index.js",
  "pkg": {
    "assets": [
      "frontend/dist/**/*"
    ],
    "targets": [
      "node18-win-x64"
    ]
  },
  "scripts": {
    "build:client": "pnpm --filter client build",
    "build:server": "pnpm --filter server build",
    "bundle:server": "ncc build server/dist/index.js -o server/bundled -m",
    "package": "pnpm build:client && pnpm build:server && pnpm bundle:server && pkg server/bundled/index.js --target node18-win-x64 --output HNetManager.exe"
  },
  "keywords": [],
  "author": "",
  "license": "ISC",
  "packageManager": "pnpm@10.30.1",
  "devDependencies": {
    "@vercel/ncc": "^0.44.1",
    "concurrently": "^10.0.3",
    "pkg": "^5.8.1"
  }
}
